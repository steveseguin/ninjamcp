  "description": "VDO.Ninja MCP bridge for WebRTC data-channel messaging, file transfer, and room sync.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/steveseguin/ninjamcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steveseguin/ninjamcp.git"
  },
