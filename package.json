    "references/mcp-tool-contract.md",
    "references/quickstart-and-compat.md",
    "references/vdo-ninja-p2p-data-notes.md",
    "scripts/demo-file-workflow.js",
    "scripts/demo-message-workflow.js",
    "scripts/install-mcp.js",
    "scripts/vdo-data-bridge.js",
    "scripts/vdo-mcp-server.js",
    "scripts/vdo-mcp-streamable-http.js",
    "scripts/lib/bridge-session.js",
    "scripts/lib/bridge-utils.js",
    "scripts/lib/fake-network-sdk.js",
